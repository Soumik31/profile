{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "soumik-shadman-site",
  "compatibility_date": "2026-07-21",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [".git", ".wrangler", "node_modules", "wrangler.jsonc"]
  },
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false
}
